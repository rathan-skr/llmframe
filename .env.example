# === LLM Provider Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === API Security ===
# Set this to protect all endpoints with X-API-Key header auth.
# Leave empty to disable auth (useful for local dev).
API_SECRET_KEY=change-this-before-deploying

# === LLM Settings ===
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-opus-4-8

# === Embedding Settings ===
# "openai"  → uses text-embedding-3-small via OpenAI API (requires OPENAI_API_KEY)
# "local"   → runs BAAI/bge-large-en-v1.5 on CPU (no API key, no cost)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# === RAG Pipeline ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVED_CHUNKS=5

# Hybrid search: BM25 keyword + vector similarity merged via RRF
HYBRID_SEARCH_ENABLED=false

# Reranking: cross-encoder scores each (query, chunk) pair directly
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === Vector Store ===
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma
VECTOR_COLLECTION=documents
# PINECONE_API_KEY=
# PINECONE_INDEX=

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/llmframe.log
